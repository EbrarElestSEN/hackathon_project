@model IEnumerable<hackathon_project.Models.Urunler>

@{
    ViewData["Title"] = "Menü";

    // Ürün ismine göre akıllı resim seçme fonksiyonu
    string GetImageForProduct(string urunAdi)
    {
        var name = urunAdi.ToLower();

        if (name.Contains("burger") || name.Contains("whopper") || name.Contains("king") || name.Contains("kumru") || name.Contains("mac"))
            return "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=400&q=80"; // Hamburger Resmi

        if (name.Contains("pizza") || name.Contains("margherita"))
            return "https://images.unsplash.com/photo-1513104890d38-7c7f4ac1e6a2?auto=format&fit=crop&w=400&q=80"; // Pizza Resmi

        if (name.Contains("döner") || name.Contains("iskender") || name.Contains("dürüm"))
            return "https://images.unsplash.com/photo-1619599507851-d419e09d57a9?auto=format&fit=crop&w=400&q=80"; // Döner/Dürüm Resmi

        if (name.Contains("tavuk") || name.Contains("zinger") || name.Contains("kanat") || name.Contains("kova"))
            return "https://images.unsplash.com/photo-1626082927389-6cd097cdc6ec?auto=format&fit=crop&w=400&q=80"; // Çıtır Tavuk Resmi

        if (name.Contains("kola") || name.Contains("ayran") || name.Contains("limonata") || name.Contains("ice tea") || name.Contains("mocha") || name.Contains("pepsi"))
            return "https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=400&q=80"; // İçecek Resmi

        if (name.Contains("sufle") || name.Contains("cheesecake") || name.Contains("tiramisu") || name.Contains("flurry"))
            return "https://images.unsplash.com/photo-1551024601-bec78aea704b?auto=format&fit=crop&w=400&q=80"; // Tatlı Resmi

        // Hiçbirine uymazsa varsayılan şık bir yemek resmi
        return "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=400&q=80";
    }
}

<style>
    body {
        background-color: #121418;
        color: #FFFFFF;
        font-family: sans-serif;
    }

    .stepper-section {
        text-align: center;
        margin-top: 30px;
        margin-bottom: 30px;
    }

    .step-subtitle-top {
        color: #FF6B00;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .main-title {
        font-size: 2.2rem;
        font-weight: 700;
        margin-top: 5px;
    }

    /* Kategori Seçim Yapısı */
    .category-filter-row {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-bottom: 25px;
    }

    .btn-filter {
        background-color: #1E2128;
        border: 1px solid #2A2D35;
        color: #8A8F98;
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-filter.active {
            background-color: #FF6B00;
            color: white;
            border-color: #FF6B00;
        }

    /* Ürün Kartları */
    .menu-card {
        background-color: #1E2128;
        border: 1px solid #2A2D35;
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .menu-img-box {
        height: 160px;
        background-color: #2A2D35;
        position: relative;
    }

        .menu-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .type-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background-color: #FF6B00;
        color: white;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .menu-info {
        padding: 15px;
    }

    .menu-title-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .prod-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .prod-price {
        color: #FF6B00;
        font-weight: 700;
        font-size: 1.1rem;
    }

    /* Ekle Butonu */
    .btn-add-basket {
        background-color: #FF6B00;
        color: white;
        border: none;
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-add-basket:hover {
            background-color: #E05E00;
            color: white;
        }
</style>

<div class="container mt-4">
    <div class="stepper-section">
        <div class="step-subtitle-top">ADIM 4 / 5</div>
        <h1 class="main-title">@ViewBag.RestoranAdi Menüsü</h1>
    </div>

    @* <div class="category-filter-row">
        <button class="btn-filter active">Tümü</button>
        <button class="btn-filter">Ana Yemek</button>
        <button class="btn-filter">Yan Ürün</button>
        <button class="btn-filter">İçecek</button>
    </div> *@

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var urun in Model)
            {
                // Artık rastgele index yerine akıllı resmi çekiyoruz
                string img = GetImageForProduct(urun.UrunAdi);

                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="menu-card">
                        <div class="menu-img-box">
                            <img src="@img" alt="@urun.UrunAdi">
                            <span class="type-badge">Menü</span>
                        </div>
                        <div class="menu-info">
                            <div class="menu-title-line">
                                <h3 class="prod-name">@urun.UrunAdi</h3>
                                <span class="prod-price">@urun.Fiyat.ToString("N0")TL</span>
                            </div>

                            <form asp-controller="Yurtlar" asp-action="HavuzaUrunEkle" method="post">
                                <input type="hidden" name="havuzId" value="@ViewBag.HavuzId" />
                                <input type="hidden" name="urunId" value="@urun.UrunId" />
                                <input type="hidden" name="fiyat" value="@urun.Fiyat" />
                                <input type="hidden" name="urunAdi" value="@urun.UrunAdi" />

                                <button type="submit" class="btn-add-basket">
                                    <span>+ Ekle</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>